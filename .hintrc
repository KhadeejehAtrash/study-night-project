{
  "extends": [
    "development"
  ],
  "hints": {
    "axe/aria": [
      "default",
      {
        "aria-valid-attr": "off"
      }
    ],
    "axe/structure": [
      "default",
      {
        "listitem": "off"
      }
    ],
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "script[type=importmap]"
        ]
      }
    ]
  }
}